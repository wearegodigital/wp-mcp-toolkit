{
	"name": "seanwilkinson/wp-mcp-toolkit",
	"description": "Comprehensive MCP toolkit for WordPress. Built on the official MCP Adapter.",
	"license": "GPL-2.0-or-later",
	"type": "wordpress-plugin",
	"keywords": ["wordpress", "mcp", "abilities-api", "ai", "content-management", "acf"],
	"authors": [
		{"name": "Sean Wilkinson", "homepage": "https://seanwilkinson.com"},
		{"name": "WordPress AI Team", "homepage": "https://make.wordpress.org/ai/"}
	],
	"homepage": "https://github.com/wearegodigital/wp-mcp-toolkit",
	"minimum-stability": "dev",
	"prefer-stable": true,
	"config": {
		"platform": {"php": "8.1"},
		"sort-packages": true,
		"preferred-install": "dist",
		"allow-plugins": {
			"automattic/jetpack-autoloader": true,
			"composer/installers": true,
			"cweagans/composer-patches": true,
			"dealerdirect/phpcodesniffer-composer-installer": true,
			"phpstan/extension-installer": true
		}
	},
	"autoload-dev": {"psr-4": {"WP\\MCP\\Tests\\": ["tests/"]}},
	"require": {
		"php": "^8.1",
		"automattic/jetpack-autoloader": "^3",
		"cweagans/composer-patches": "^1.7",
		"wordpress/mcp-adapter": "^0.4"
	},
	"extra": {
		"patches": {
			"wordpress/mcp-adapter": {
				"Fix stdClass input in Execute/GetAbilityInfo abilities (upstream bug)": "patches/mcp-adapter-stdclass-input.patch"
			}
		}
	},
	"require-dev": {
		"phpunit/phpunit": "^9.6",
		"yoast/phpunit-polyfills": "^4.0"
	}
}
